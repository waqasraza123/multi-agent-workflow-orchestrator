{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-runway.local/contracts/worker/agent-plan.schema.json",
  "title": "Agent worker plan generation",
  "type": "object",
  "required": ["request", "response"],
  "additionalProperties": false,
  "properties": {
    "request": {
      "$ref": "#/$defs/LlmPlanRequest"
    },
    "response": {
      "$ref": "#/$defs/LlmPlanningOutcome"
    }
  },
  "$defs": {
    "AgentExecutionProfile": {
      "type": "object",
      "required": ["agent_name", "backend", "max_retries"],
      "additionalProperties": false,
      "properties": {
        "agent_name": { "type": "string", "minLength": 1 },
        "backend": { "enum": ["deterministic", "llm"] },
        "llm_provider_name": { "type": ["string", "null"], "minLength": 1 },
        "model_name": { "type": ["string", "null"], "minLength": 1 },
        "temperature": { "type": ["number", "null"], "minimum": 0, "maximum": 2 },
        "max_output_tokens": { "type": ["integer", "null"], "minimum": 1 },
        "timeout_seconds": { "type": ["number", "null"], "exclusiveMinimum": 0 },
        "max_retries": { "type": "integer", "minimum": 0 }
      }
    },
    "LlmPlanRequest": {
      "type": "object",
      "required": ["run_id", "user_goal", "workflow_type", "execution_profile"],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "user_goal": { "type": "string", "minLength": 1 },
        "workflow_type": {
          "enum": [
            "research_report",
            "technical_plan",
            "document_analysis",
            "assisted_action"
          ]
        },
        "execution_profile": { "$ref": "#/$defs/AgentExecutionProfile" }
      }
    },
    "PlannedTask": {
      "type": "object",
      "required": [
        "task_id",
        "title",
        "description",
        "assigned_agent",
        "dependency_ids",
        "acceptance_criteria"
      ],
      "additionalProperties": false,
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "assigned_agent": { "type": "string", "minLength": 1 },
        "dependency_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance_criteria": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "LlmPlanOutput": {
      "type": "object",
      "required": ["run_id", "workflow_type", "template_name", "summary", "tasks"],
      "additionalProperties": false,
      "properties": {
        "run_id": { "type": "string", "minLength": 1 },
        "workflow_type": {
          "enum": [
            "research_report",
            "technical_plan",
            "document_analysis",
            "assisted_action"
          ]
        },
        "template_name": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/PlannedTask" }
        }
      }
    },
    "LlmUsage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "additionalProperties": false,
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "estimated_cost_usd": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "LlmPlanResponse": {
      "type": "object",
      "required": ["provider_name", "model_name", "output", "usage"],
      "additionalProperties": false,
      "properties": {
        "provider_name": { "type": "string", "minLength": 1 },
        "model_name": { "type": "string", "minLength": 1 },
        "output": { "$ref": "#/$defs/LlmPlanOutput" },
        "usage": { "$ref": "#/$defs/LlmUsage" },
        "finish_reason": { "type": ["string", "null"] },
        "latency_ms": { "type": ["integer", "null"], "minimum": 0 },
        "raw_response_text": { "type": ["string", "null"] }
      }
    },
    "LlmPlanningOutcome": {
      "type": "object",
      "required": ["output", "fallback_used", "attempt_count"],
      "additionalProperties": false,
      "properties": {
        "output": { "$ref": "#/$defs/LlmPlanOutput" },
        "llm_response": {
          "anyOf": [{ "$ref": "#/$defs/LlmPlanResponse" }, { "type": "null" }]
        },
        "error_message": { "type": ["string", "null"] },
        "fallback_used": { "type": "boolean" },
        "attempt_count": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
